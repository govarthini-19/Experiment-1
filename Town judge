class Solution:
    def findJudge(self, n: int, trust: List[List[int]]) -> int:
        inorder=[0]*(n+1)
        outorder=[0]*(n+1)
        for i,j in trust:
            outorder[i]+=1
            inorder[j]+=1
        for a in range(1,n+1):
            if inorder[a]==n-1 and outorder[a]==0:
                return a
        return -1
